                        $farmer = $_SESSION['username'];

                        $sql = "SELECT o.order_id, b.buyer_name, c.crop_name, o.quantity, c.crop_price_per_kg,
                                    (o.quantity * c.crop_price_per_kg) AS total, o.order_status
                                FROM orders o
                                INNER JOIN buyer b ON b.buyer_id = o.buyer_id
                                INNER JOIN crop c ON c.crop_id = o.crop_id
                                INNER JOIN farmer f ON f.farmer_id = c.farmer_id
                                WHERE f.farmer_username = ?";

                        $stmt = $conn->prepare($sql);
